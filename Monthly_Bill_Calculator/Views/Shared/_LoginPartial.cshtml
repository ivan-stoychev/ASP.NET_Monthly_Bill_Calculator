@using Microsoft.AspNetCore.Identity
@using Monthly_Bill_Calculator.DB_Models

@inject SignInManager<CalcAppUser> SignInManager
@inject UserManager<CalcAppUser> UserManager

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- Greeting only, no Identity-area navigation -->
        <li class="nav-item">
            <span class="nav-link text-dark">
                Hello @UserManager.GetUserName(User)!
            </span>
        </li>

        <!-- Logout (Identity needs this) -->
        <li class="nav-item">
            <form id="logoutForm"
                  class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button id="logout"
                        type="submit"
                        class="nav-link btn btn-link text-dark border-0">
                    Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark"
               id="register"
               asp-area="Identity"
               asp-page="/Account/Register">
                Register
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link text-dark"
               id="login"
               asp-area="Identity"
               asp-page="/Account/Login">
                Login
            </a>
        </li>
    }
</ul>