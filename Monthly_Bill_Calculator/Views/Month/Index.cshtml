@model IEnumerable<Monthly_Bill_Calculator.DB_Models.Month>

@{
    ViewData["Title"] = "Unpaid Bills";
}

<h2 class="mb-4">Your Unpaid Bills</h2>

@if (!Model.Any())
{
    <div class="alert alert-success">
        You have no unpaid bills.
    </div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Year</th>
                <th>Month</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var m in Model)
            {
                decimal total = m.Total;

                <tr>
                    <td>@m.Year</td>
                    <td>@m.MonthNumber</td>
                    <td class="fw-bold">@total.ToString("0.00")</td>

                    <td>
                        <form asp-action="MarkAsPaid" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@m.Id" />
                            <button class="btn btn-success btn-sm">Pay</button>
                        </form>

                        <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-info btn-sm ms-2">
                            Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}