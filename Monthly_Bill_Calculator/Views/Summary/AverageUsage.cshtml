@model Monthly_Bill_Calculator.Models.SummaryViewModel

@{
    ViewData["Title"] = "Average Usage Summary";
}

<h2 class="mb-4">Average Usage Summary</h2>

<form method="post" class="mb-4">
    @Html.Partial("_DateRangeForm", Model)
</form>

@if (Model.Utilities != null)
{
    <div class="alert alert-info">
        <strong>Showing averages for:</strong>
        @Model.StartMonth/@Model.StartYear – @Model.EndMonth/@Model.EndYear
    </div>

    <h3 class="mt-4">Average Values</h3>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Utility</th>
                <th>Average Consumption</th>
                <th>Average Spent</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Utilities)
            {
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value.AvgConsumption.ToString("0.00")</td>
                    <td>@item.Value.AvgPrice.ToString("0.00")</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr class="table-secondary fw-bold">
                <td colspan="2" class="text-end">Average spent per month:</td>
                <td>@Model.TotalAverageSpent.ToString("0.00")</td>
            </tr>
        </tfoot>
    </table>
}