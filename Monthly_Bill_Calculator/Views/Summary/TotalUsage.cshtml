@model Monthly_Bill_Calculator.Models.SummaryViewModel

@{
    ViewData["Title"] = "Total Usage Summary";
}

<h2 class="mb-4">Total Usage Summary</h2>

<form method="post" class="mb-4">
    @Html.Partial("_DateRangeForm", Model)
</form>

@if (Model.Utilities != null)
{
    <div class="alert alert-info">
        <strong>Showing totals for:</strong>
        @Model.StartMonth/@Model.StartYear – @Model.EndMonth/@Model.EndYear
    </div>

    <h3 class="mt-4">Total Values</h3>

    <table class="table table-bordered table-striped">
        <thead class="table-light">
            <tr>
                <th>Utility</th>
                <th>Total Consumption</th>
                <th>Total Spent</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model.Utilities)
            {
                <tr>
                    <td>@item.Key</td>
                    <td>@item.Value.TotalConsumption.ToString("0.00")</td>
                    <td>@item.Value.TotalPrice.ToString("0.00")</td>
                </tr>
            }
        </tbody>

        <tfoot>
            <tr class="table-secondary fw-bold">
                <td colspan="2" class="text-end">Total spent on bills:</td>
                <td>@Model.TotalSpent.ToString("0.00")</td>
            </tr>
        </tfoot>
    </table>
}