@model IEnumerable<string>

<h2>Manage Roles for @ViewBag.UserName</h2>

<div class="row mt-4">
    <div class="col-md-6">
        <h4>Current Roles</h4>
        <ul class="list-group mb-4">
            @foreach (var role in Model)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    @role
                    <form asp-action="RemoveFromRole" method="post" style="display:inline;">
                        <input type="hidden" name="userId" value="@ViewBag.UserId" />
                        <input type="hidden" name="roleName" value="@role" />
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </li>
            }
        </ul>
    </div>

    <div class="col-md-6">
        <h4>Add New Role</h4>
        <form asp-action="AddToRole" method="post" class="card card-body">
            <input type="hidden" name="userId" value="@ViewBag.UserId" />
            <div class="input-group">
                <select name="roleName" class="form-select">
                    @foreach (var role in (IEnumerable<string>)ViewBag.AllRoles)
                    {
                        if (!Model.Contains(role))
                        {
                            <option value="@role">@role</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-success">Add Role</button>
            </div>
        </form>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>