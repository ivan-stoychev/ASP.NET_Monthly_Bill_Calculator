@model IEnumerable<Monthly_Bill_Calculator.DB_Models.Bill>

@{
    ViewData["Title"] = "Bills";
}

<h2>Bills</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Bill</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Amount</th>
            <th>User</th>
            <th>Paid</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var bill in Model)
        {
            <tr>
                <td>@bill.Title</td>
                <td>@bill.Amount.ToString("0.00")</td>
                <td>@bill.User?.Email</td>

                <td>
                    @{
                        if (bill.IsPaid)
                        {
                            <span class="badge bg-success">Paid</span>
                            ;
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Unpaid</span>
                            ;
                        }
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-id="@bill.Id" class="btn btn-sm btn-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@bill.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>