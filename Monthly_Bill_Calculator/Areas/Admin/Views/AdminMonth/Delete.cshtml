@model Monthly_Bill_Calculator.DB_Models.Month

@{
    ViewData["Title"] = "Delete Bill";
}

<h2 class="mb-4 text-danger">Delete Bill</h2>

<div class="alert alert-warning">
    <strong>Are you sure you want to delete this bill?</strong>
    <br />
    This action cannot be undone.
</div>

<div class="card mb-4">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.User?.Email</dd>

            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Month</dt>
            <dd class="col-sm-9">@Model.MonthNumber</dd>

            <dt class="col-sm-3">Total</dt>
            <dd class="col-sm-9">@Model.Total.ToString("0.00")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsPaid)
                {
                    <span class="badge bg-success">Paid</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Unpaid</span>
                }
            </dd>

        </dl>

    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>