@model Monthly_Bill_Calculator.DB_Models.Month

@{
    ViewData["Title"] = "Bill Details";
}

<h2 class="mb-4">Bill Details</h2>

<div class="card mb-4">
    <div class="card-body">

        <dl class="row">

            <dt class="col-sm-3">User</dt>
            <dd class="col-sm-9">@Model.User?.Email</dd>

            <dt class="col-sm-3">Year</dt>
            <dd class="col-sm-9">@Model.Year</dd>

            <dt class="col-sm-3">Month</dt>
            <dd class="col-sm-9">@Model.MonthNumber</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                @if (Model.IsPaid)
                {
                    <span class="badge bg-success">Paid</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Unpaid</span>
                }
            </dd>

            <dt class="col-sm-3">Total Cost</dt>
            <dd class="col-sm-9 fw-bold">@Model.Total.ToString("0.00")</dd>

        </dl>

    </div>
</div>

<hr />

<h4>Utility Breakdown</h4>

<div class="mt-3">

    @if (Model.Electricity != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Electricity</h5>
            <p>Consumption: @Model.Electricity.Consumption @Model.Electricity.Unit</p>
            <p>Price per Unit: @Model.Electricity.Price</p>
            <p><strong>Cost: @Model.Electricity.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

    @if (Model.ColdWater != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Cold Water</h5>
            <p>Consumption: @Model.ColdWater.Consumption m³</p>
            <p>Price per m³: @Model.ColdWater.Price</p>
            <p><strong>Cost: @Model.ColdWater.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

    @if (Model.HotWater != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Hot Water</h5>
            <p>Consumption: @Model.HotWater.Consumption m³</p>
            <p>Price per m³: @Model.HotWater.Price</p>
            <p><strong>Cost: @Model.HotWater.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

    @if (Model.NaturalGas != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Natural Gas</h5>
            <p>Consumption: @Model.NaturalGas.Consumption m³</p>
            <p>Price per m³: @Model.NaturalGas.Price</p>
            <p><strong>Cost: @Model.NaturalGas.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

    @if (Model.Steam != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Steam</h5>
            <p>Consumption: @Model.Steam.Consumption</p>
            <p>Price per Unit: @Model.Steam.Price</p>
            <p><strong>Cost: @Model.Steam.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

    @if (Model.CentralHeating != null)
    {
        <div class="border rounded p-3 mb-3">
            <h5>Central Heating</h5>
            <p>Consumption: @Model.CentralHeating.Consumption</p>
            <p>Price per Unit: @Model.CentralHeating.Price</p>
            <p><strong>Cost: @Model.CentralHeating.MonthlyCost.ToString("0.00")</strong></p>
        </div>
    }

</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>